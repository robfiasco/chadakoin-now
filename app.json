{
  "expo": {
    "name": "Chadakoin Now",
    "slug": "chadakoin-now",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/files/icon-chadakoin.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/files/icon-chadakoin.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0b08"
    },
    "ios": {
      "bundleIdentifier": "com.chadakoinnow",
      "appleTeamId": "3UM77ULJKQ",
      "buildNumber": "8",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.chadakoindigital.chadakoinnow"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/files/icon-chadakoin-android.png",
        "backgroundColor": "#0f0b08"
      },
      "versionCode": 26,
      "package": "com.chadakoinnow",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "scheme": "chadakoin-now",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/files/icon-chadakoin.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-audio",
      "@bacons/apple-targets",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0b08",
          "image": "./assets/files/icon-chadakoin.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a175214-38af-4fa5-bc82-55a9640593d9"
      }
    },
    "owner": "robfiasco"
  }
}
