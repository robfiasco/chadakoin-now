{
  "expo": {
    "name": "Chadakoin Now",
    "slug": "chadakoin-now",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/files/icon-chadakoin.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f0b08"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/files/icon-chadakoin.png",
        "backgroundColor": "#0f0b08"
      },
      "versionCode": 3,
      "package": "com.chadakoinnow"
    },
    "scheme": "chadakoin-now",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/files/favicon-chadakoin.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-audio"
    ]
  }
}
