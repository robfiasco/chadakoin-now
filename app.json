{
  "expo": {
    "name": "Chadakoin Now",
    "slug": "chadakoin-now",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon_blue.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#163A59"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon_blue.png",
        "backgroundColor": "#163A59"
      },
      "versionCode": 2,
      "package": "com.chadakoinnow"
    },
    "scheme": "chadakoin-now",
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-audio"
    ]
  }
}
