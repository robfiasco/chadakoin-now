{
  "expo": {
    "name": "Chadakoin Now",
    "slug": "chadakoin-now",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/files/icon-chadakoin.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f0b08"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/files/icon-chadakoin.png",
        "backgroundColor": "#0f0b08"
      },
      "versionCode": 4,
      "package": "com.chadakoinnow",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "scheme": "chadakoin-now",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/files/icon-chadakoin.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-audio"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a175214-38af-4fa5-bc82-55a9640593d9"
      }
    },
    "owner": "robfiasco"
  }
}
