{
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/:file.(jpg|jpeg|png|webp|gif|ico|svg)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/_expo/static/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/api/proxy",         "destination": "/api/proxy" },
    { "source": "/api/weather",       "destination": "/api/weather" },
    { "source": "/api/cdir",          "destination": "/api/cdir" },
    { "source": "/api/sabres",        "destination": "/api/sabres" },
    { "source": "/api/mlb",           "destination": "/api/mlb" },
    { "source": "/api/feedback",      "destination": "/api/feedback" },
    { "source": "/api/source-health", "destination": "/api/source-health" },
    { "source": "/api/gas",           "destination": "/api/gas" }
  ]
}
